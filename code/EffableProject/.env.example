BOT_TOKEN=1234567890:ABCDEF_your_real_token_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- PostgreSQL (for SQLAlchemy asyncpg) ---
# Вариант 1: укажи сразу DATABASE_URL (для локального запуска — localhost)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/effable_bot

# Вариант 2 (если не задаешь DATABASE_URL): раздельные переменные
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=effable_bot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# --- Docker Compose ---
# В docker-compose.yml для сервиса `bot` задаётся свой DATABASE_URL с хостом `postgres`
# (имя сервиса в сети compose). Локальный DATABASE_URL с localhost там переопределяется,
# чтобы бот в контейнере подключался к контейнеру БД, а не к хосту.

